---
# validation_check is a module built into the ZT runner image at runtime.
# It is not installable in CI, so exclude validation.yml files from ansible-lint.
# yamllint and ansible-playbook --syntax-check still cover these files.
exclude_paths:
  - runtime-automation/scenario-1/validation.yml
  - runtime-automation/scenario-2/validation.yml
  - runtime-automation/scenario-3/validation.yml
  - runtime-automation/scenario-4/validation.yml
  - runtime-automation/scenario-5/validation.yml
  - runtime-automation/scenario-6/validation.yml

# kubernetes.core.k8s_exec is available in the FTL runner image at runtime
# but is not installed in CI — mock it so ansible-lint can resolve it.
mock_modules:
  - kubernetes.core.k8s_exec
